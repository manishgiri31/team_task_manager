# Application Configuration
APP_NAME=Team Task Manager API
APP_VERSION=1.0.0
DEBUG=False

# Database Configuration (PostgreSQL)
# Local async URL:
#   postgresql+asyncpg://user:password@host:port/database
# Railway / Heroku often provide:
#   postgresql://... or postgres://...
# The app normalizes these to postgresql+asyncpg:// at startup.
DATABASE_URL=postgresql+asyncpg://postgres:root@localhost:5432/team_task_manager

# JWT Configuration
# Generate a secure random key using: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Configuration
# Comma-separated list of allowed origins (no spaces, or spaces trimmed in app)
# Production example: https://your-app.vercel.app,https://your-api.up.railway.app
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Optional: default admin on startup (all three required; skipped if any missing)
# If a user with ADMIN_EMAIL already exists, nothing is created (idempotent).
# Use a strong password (min 8 characters). Do not commit real secrets.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@123
ADMIN_NAME=System Administrator
